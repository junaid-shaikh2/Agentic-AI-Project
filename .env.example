# Weather forecast API key from OpenWeatherMap.
OPENWEATHER_API_KEY=your_openweather_key

# Ticketmaster Developer Portal Consumer Key.
TICKETMASTER_API_KEY=your_ticketmaster_consumer_key

# Geoapify API key used for geocoding and places.
GEOAPIFY_API_KEY=your_geoapify_key

# NewsAPI key used for lightweight travel advisory monitoring.
NEWS_API_KEY=your_newsapi_key

# Gmail SMTP settings. Use a Gmail App Password, not your normal password.
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# Optional LLM settings.
LLM_API_KEY=your_openai_api_key
LLM_MODEL=gpt-4o-mini
